---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCategory from '../components/ServiceCategory.astro';
import { services as staticServices, categories, type CategoryKey } from '../data/services';
import { fetchWithFallback, queries } from '../lib/sanity';
export const prerender = true;

// Try Sanity, fall back to static data
const sanityServices = await fetchWithFallback(queries.services, null);
const servicesData = sanityServices && Array.isArray(sanityServices) && sanityServices.length > 0
  ? sanityServices
  : staticServices;

// Group services by category, preserving the same interface as getServicesByCategory
function getServicesByCat(category: CategoryKey) {
  return servicesData.filter((s: { category: string }) => s.category === category);
}
---

<BaseLayout
  title="Servizi"
  description="Tutti i servizi della Vetreria Monferrina: box doccia, parapetti, pensiline, vetri camera, specchi e lavorazioni su misura."
>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="font-heading text-4xl text-primary mb-4">I nostri servizi</h1>
    <p class="text-lg text-neutral-700 mb-12">
      Oltre 40 anni di esperienza nella lavorazione del vetro.
    </p>

    {Object.entries(categories).map(([key, title]) => (
      <ServiceCategory
        title={title}
        services={getServicesByCat(key as CategoryKey)}
      />
    ))}
  </section>
</BaseLayout>
