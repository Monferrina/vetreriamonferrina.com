---
// src/pages/trasporto-e-montaggio.astro — Servizio trasporto, montaggio e smaltimento vetri.
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout
  title="Trasporto e montaggio"
  description="Trasporto sicuro e montaggio professionale del vetro a Casale Monferrato e in tutto il Piemonte. Sopralluogo gratuito, posa in opera a regola d'arte."
>
  <section class="bg-primary py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <h1 class="font-heading text-4xl text-neutral-50 sm:text-5xl">Trasporto e montaggio</h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-neutral-200">
        Dal nostro laboratorio a casa tua, con posa professionale. Ci occupiamo di tutto noi:
        misure, trasporto e installazione.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
    <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-12" data-reveal>
      Come funziona
    </h2>

    <div class="grid gap-8 sm:grid-cols-3">
      <div data-reveal data-delay="1" class="group pb-1">
        <div
          class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
        >
          <div
            class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
          >
            <svg
              class="h-8 w-8 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
              ></path>
            </svg>
          </div>
          <span
            class="mt-4 inline-block rounded-full bg-primary px-3 py-1 text-sm font-semibold text-neutral-50"
          >
            1
          </span>
          <h3 class="mt-3 font-heading text-xl text-primary">Sopralluogo gratuito</h3>
          <p class="mt-2 text-neutral-800">
            Veniamo da te per prendere le misure e valutare insieme il lavoro. Senza impegno e senza
            costi.
          </p>
        </div>
      </div>

      <div data-reveal data-delay="2" class="group pb-1">
        <div
          class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
        >
          <div
            class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
          >
            <svg
              class="h-8 w-8 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"
              ></path>
            </svg>
          </div>
          <span
            class="mt-4 inline-block rounded-full bg-primary px-3 py-1 text-sm font-semibold text-neutral-50"
          >
            2
          </span>
          <h3 class="mt-3 font-heading text-xl text-primary">Trasporto sicuro</h3>
          <p class="mt-2 text-neutral-800">
            Mezzi attrezzati per il trasporto di vetro di ogni dimensione. Protezione e cura in ogni
            fase, dal laboratorio al cantiere.
          </p>
        </div>
      </div>

      <div data-reveal data-delay="3" class="group pb-1">
        <div
          class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
        >
          <div
            class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
          >
            <svg
              class="h-8 w-8 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z"
              ></path>
            </svg>
          </div>
          <span
            class="mt-4 inline-block rounded-full bg-primary px-3 py-1 text-sm font-semibold text-neutral-50"
          >
            3
          </span>
          <h3 class="mt-3 font-heading text-xl text-primary">Montaggio professionale</h3>
          <p class="mt-2 text-neutral-800">
            Posa in opera a regola d'arte da parte dei nostri vetrai esperti. Pulizia del cantiere e
            collaudo finale inclusi.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-neutral-50 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-4" data-reveal>
        Cosa installiamo
      </h2>
      <p
        class="mx-auto mt-4 max-w-2xl text-center text-lg leading-relaxed text-neutral-800 mb-12"
        data-reveal
        data-delay="1"
      >
        Trasportiamo e installiamo tutto ciò che produciamo nel nostro laboratorio.
      </p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          [
            {
              name: 'Box doccia',
              description: 'Montaggio completo con fissaggi, cerniere e guarnizioni.',
              href: '/servizi',
            },
            {
              name: 'Parapetti in vetro',
              description: 'Installazione su balconi, terrazze e scale con fissaggi certificati.',
              href: '/servizi',
            },
            {
              name: 'Pensiline',
              description: 'Posa di pensiline in vetro per ingressi e spazi esterni.',
              href: '/servizi',
            },
            {
              name: 'Vetrine per negozi',
              description: 'Installazione di vetrine commerciali di qualsiasi dimensione.',
              href: '/servizi',
            },
            {
              name: 'Specchi e porte',
              description:
                'Montaggio di specchi a parete e porte in vetro, scorrevoli o a battente.',
              href: '/servizi',
            },
            {
              name: 'Vetri camera e finestre',
              description:
                'Sostituzione vetri e posa di vetrocamera per isolamento termico e acustico.',
              href: '/servizi',
            },
          ].map((item) => (
            <a
              href={item.href}
              class="group rounded-2xl border border-neutral-200 bg-surface p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md"
            >
              <h3 class="font-heading text-lg text-primary group-hover:text-primary-dark">
                {item.name}
              </h3>
              <p class="mt-2 text-sm text-neutral-800">{item.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-surface py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-4" data-reveal>
        Zone servite
      </h2>
      <p
        class="mx-auto mt-4 max-w-2xl text-center text-lg leading-relaxed text-neutral-800"
        data-reveal
        data-delay="1"
      >
        Da Casale Monferrato operiamo in tutto il Nord-Ovest e oltre confine, con sopralluoghi
        gratuiti nelle aree principali.
      </p>

      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <div data-reveal data-delay="1" class="group pb-1">
          <div
            class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-8 w-8 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                ></path>
              </svg>
            </div>
            <h3 class="mt-4 font-heading text-xl text-primary">Piemonte</h3>
            <p class="mt-2 text-neutral-800">
              La nostra zona principale. Casale Monferrato, Alessandria, Asti, Torino, Vercelli,
              Novara e tutte le province.
            </p>
            <span
              class="mt-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
              >Sopralluogo gratuito</span
            >
          </div>
        </div>

        <div data-reveal data-delay="2" class="group pb-1">
          <div
            class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-8 w-8 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                ></path>
              </svg>
            </div>
            <h3 class="mt-4 font-heading text-xl text-primary">Lombardia</h3>
            <p class="mt-2 text-neutral-800">
              Gamma completa di servizi. Pavia, Milano, Vigevano, Voghera e province limitrofe.
            </p>
            <span
              class="mt-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
              >Sopralluogo gratuito</span
            >
          </div>
        </div>

        <div data-reveal data-delay="3" class="group pb-1">
          <div
            class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-8 w-8 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"
                ></path>
              </svg>
            </div>
            <h3 class="mt-4 font-heading text-xl text-primary">Liguria e Valle d'Aosta</h3>
            <p class="mt-2 text-neutral-800">
              Disponibili per installazioni di grandi dimensioni e progetti speciali su preventivo.
            </p>
            <span
              class="mt-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
              >Progetti speciali</span
            >
          </div>
        </div>

        <div data-reveal data-delay="4" class="group pb-1">
          <div
            class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-8 w-8 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"
                ></path>
              </svg>
            </div>
            <h3 class="mt-4 font-heading text-xl text-primary">Estero</h3>
            <p class="mt-2 text-neutral-800">
              Esperienza anche oltre confine. Contattateci per valutare insieme il vostro progetto.
            </p>
            <span
              class="mt-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
              >Valutazione su richiesta</span
            >
          </div>
        </div>
      </div>

      <div
        data-reveal
        class="mt-12 rounded-2xl border border-neutral-200 bg-neutral-50 p-6 text-center shadow-sm sm:p-8"
      >
        <p class="reassure-link text-lg text-neutral-800">
          Non sei sicuro che arriviamo da te?
          <strong class="text-primary">Chiamaci</strong>, ci organizziamo sempre.
        </p>
        <div class="mt-4 flex flex-wrap items-center justify-center gap-4">
          <a
            href="tel:+390142563728"
            class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-2.5 text-sm font-semibold text-neutral-50 transition-colors hover:bg-primary-dark"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
              ></path>
            </svg>
            0142 563728
          </a>
          <a
            href="https://wa.me/393355955786"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-[#25D366] px-6 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-neutral-50 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-4" data-reveal>
        Conformità e garanzie
      </h2>
      <p
        class="mx-auto mt-4 max-w-2xl text-center text-lg leading-relaxed text-neutral-800 mb-12"
        data-reveal
        data-delay="1"
      >
        Trasporto e montaggio eseguiti nel pieno rispetto delle normative italiane vigenti. Ogni
        intervento è a regola d'arte, anche dal punto di vista legale.
      </p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div
          data-reveal
          data-delay="1"
          class="rounded-2xl border border-neutral-200 bg-surface p-6 shadow-sm"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 mb-4">
            <svg
              class="h-6 w-6 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
              ></path>
            </svg>
          </div>
          <h3 class="font-heading text-lg text-primary">Normativa UNI 7697</h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-800">
            Criteri di sicurezza per vetrate installate negli edifici. Ogni posa rispetta le
            prescrizioni sulla scelta del tipo di vetro in base alla destinazione d'uso.
          </p>
        </div>

        <div
          data-reveal
          data-delay="2"
          class="rounded-2xl border border-neutral-200 bg-surface p-6 shadow-sm"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 mb-4">
            <svg
              class="h-6 w-6 text-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
              ></path>
            </svg>
          </div>
          <h3 class="font-heading text-lg text-primary">D.Lgs. 81/2008</h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-800">
            Sicurezza sul lavoro: i nostri operatori sono formati e dotati di tutti i dispositivi di
            protezione individuale previsti dalla legge.
          </p>
