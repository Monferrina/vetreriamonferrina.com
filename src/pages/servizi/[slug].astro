---
// src/pages/servizi/[slug].astro — Pagina servizio individuale con caratteristiche, materiali e servizi correlati.
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaSection from '../../components/CtaSection.astro';
import GlassPanel from '../../components/GlassPanel.astro';
import { services, type Service } from '../../data/services';
import { serviceDetails } from '../../data/service-details';
export const prerender = true;

export function getStaticPaths() {
  return services.filter((s) => serviceDetails[s.slug]).map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = services.find((s) => s.slug === slug)!;
const details = serviceDetails[slug!]!;

// Related services: curated list when defined, otherwise same category (excluding current)
const related: Service[] = details.related
  ? details.related
      .map((relSlug) => services.find((s) => s.slug === relSlug))
      .filter((s): s is Service => Boolean(s))
  : services.filter((s) => s.category === service.category && s.slug !== slug).slice(0, 3);
const hasMaterials = Boolean(details.materials && details.materials.length > 0);
const hasWhenToChoose = Boolean(details.whenToChoose);
const hasFaq = Boolean(details.faq && details.faq.length > 0);

// Sfondi alternati per le sezioni dopo "Caratteristiche" (che è bg-neutral-50): partono da bg-surface.
const sectionOrder = [
  hasMaterials && 'materials',
  hasWhenToChoose && 'whenToChoose',
  hasFaq && 'faq',
  related.length > 0 && 'related',
].filter(Boolean) as string[];
const bgFor: Record<string, string> = {};
sectionOrder.forEach((key, i) => {
  bgFor[key] = i % 2 === 0 ? 'bg-surface' : 'bg-neutral-50';
});

// Structured data FAQPage (rich snippet) quando ci sono FAQ.
const faqSchema = hasFaq
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: details.faq!.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

// Structured data BreadcrumbList: Home > Servizi > servizio corrente.
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://vetreriamonferrina.com' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Servizi',
      item: 'https://vetreriamonferrina.com/servizi',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: service.name,
      item: `https://vetreriamonferrina.com/servizi/${slug}`,
    },
  ],
};
---

<BaseLayout
  title={`${service.name} a Casale Monferrato`}
  description={details.seoDescription}
  ogImage={service.image ? `https://vetreriamonferrina.com${service.image}` : undefined}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="bg-primary py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <GlassPanel class="max-w-3xl">
        <nav class="mb-4 text-sm text-neutral-300" aria-label="Breadcrumb">
          <a href="/servizi" class="transition-colors hover:text-neutral-50">Servizi</a>
          <span class="mx-2">/</span>
          <span class="text-neutral-50">{service.name}</span>
        </nav>
        <h1 class="font-heading text-4xl text-neutral-50 sm:text-5xl">{service.name}</h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-neutral-200">
          {details.intro}
        </p>
      </GlassPanel>
    </div>
  </section>

  <section class="bg-neutral-50 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      {
        service.image && (
          <div class="mx-auto mb-12 max-w-sm sm:max-w-md" data-reveal>
            <img
              src={service.image}
              alt={service.description}
              class="w-full rounded-2xl shadow-md"
              loading="eager"
            />
          </div>
        )
      }

      <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-12" data-reveal>
        Caratteristiche
      </h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {
          details.features.map((feat, i) => (
            <div data-reveal data-delay={String((i % 4) + 1)} class="group pb-1">
              <div class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-6 shadow-sm transition-all duration-200 group-hover:-translate-y-1">
                <h3 class="font-heading text-lg text-primary">{feat.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-neutral-800">{feat.text}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    hasMaterials && (
      <section class:list={[bgFor.materials, 'py-16 sm:py-20']}>
        <div class="mx-auto max-w-7xl px-4 lg:px-8">
          <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-8" data-reveal>
            Materiali disponibili
          </h2>
          <div class="flex flex-wrap justify-center gap-3" data-reveal data-delay="1">
            {details.materials!.map((mat) => (
              <span class="rounded-full border border-neutral-200 bg-neutral-50 px-5 py-2.5 text-sm font-medium text-neutral-800 transition-colors hover:border-primary hover:text-primary">
                {mat}
              </span>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    hasWhenToChoose && (
      <section class:list={[bgFor.whenToChoose, 'py-16 sm:py-20']}>
        <div class="mx-auto max-w-3xl px-4 lg:px-8" data-reveal>
          <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-6">
            Quando scegliere {service.name.toLowerCase()}
          </h2>
          <p class="text-lg leading-relaxed text-neutral-800">{details.whenToChoose}</p>
        </div>
      </section>
    )
  }

  {
    hasFaq && (
      <section class:list={[bgFor.faq, 'py-16 sm:py-20']}>
        <div class="mx-auto max-w-3xl px-4 lg:px-8">
          <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-8" data-reveal>
            Domande frequenti
          </h2>
          <div class="space-y-4">
            {details.faq!.map((item, i) => (
              <details
                class="group rounded-2xl border border-neutral-200 bg-surface p-5 shadow-sm"
                data-reveal
                data-delay={String((i % 4) + 1)}
              >
                <summary class="flex cursor-pointer items-center justify-between gap-4 font-heading text-lg text-primary marker:content-none">
                  {item.q}
                  <span
                    class="shrink-0 text-2xl text-primary transition-transform duration-200 group-open:rotate-45"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <p class="mt-3 text-base leading-relaxed text-neutral-800">{item.a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  {
    related.length > 0 && (
      <section class:list={[bgFor.related, 'py-16 sm:py-20']}>
        <div class="mx-auto max-w-7xl px-4 lg:px-8">
          <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-8" data-reveal>
            Servizi correlati
          </h2>
          <div
            class:list={[
              'grid gap-6',
              related.length === 1 && 'max-w-md mx-auto',
              related.length === 2 && 'sm:grid-cols-2 max-w-3xl mx-auto',
              related.length >= 3 && 'sm:grid-cols-2 lg:grid-cols-3',
            ]}
          >
            {related.map((rel, i) => (
              <a
                href={`/servizi/${rel.slug}`}
                data-reveal
                data-delay={String(i + 1)}
                class="group pb-1 block"
              >
                <div class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-6 shadow-sm transition-all duration-200 group-hover:-translate-y-1">
                  <h3 class="font-heading text-lg text-primary group-hover:text-primary-dark">
                    {rel.name}
                  </h3>
                  <p class="mt-2 text-sm text-neutral-800">{rel.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CtaSection
    title="Interessato? Richiedi un preventivo"
    description="Sopralluogo gratuito, preventivo senza impegno e installazione professionale."
  />
</BaseLayout>
