---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactMap from '../components/ContactMap.astro';
import WeatherWidget from '../components/WeatherWidget.astro';
import { fetchWithFallback, queries } from '../lib/sanity';
export const prerender = true;

// Fetch site settings from Sanity for contact details
interface OpeningHour {
  days: string;
  hours: string;
}
interface SiteSettings {
  address?: string;
  city?: string;
  phone?: string;
  email?: string;
  openingHours?: OpeningHour[];
}

const settings = await fetchWithFallback<SiteSettings | null>(queries.siteSettings, null);

// Opening hours: Google Places data (build-time) → Sanity → static fallback
let googleHours: OpeningHour[] = [];
try {
  const hoursData = await import('../data/opening-hours.json');
  googleHours = hoursData.schedule || [];
} catch {
  /* file not yet generated */
}

const address = settings?.address || 'Strada Statale 31, 98/C';
const city = settings?.city || '15033 Casale Monferrato (AL)';
const phone = settings?.phone || '+39 0142 563728';
const email = settings?.email || 'vetreriamonferrina@gmail.com';
const openingHours: OpeningHour[] =
  settings?.openingHours && settings.openingHours.length > 0
    ? settings.openingHours
    : googleHours.length > 0
      ? googleHours
      : [
          { days: 'Lunedì - Venerdì', hours: '08:00 - 12:00 / 13:30 - 17:30' },
          { days: 'Sabato', hours: '08:00 - 12:00' },
          { days: 'Domenica', hours: 'Chiuso' },
        ];
---

<BaseLayout
  title="Contatti"
  description="Contatta la Vetreria Monferrina a Casale Monferrato: indirizzo, telefono, email e orari di apertura."
>
  <!-- Hero section -->
  <section class="bg-primary py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <h1 class="font-heading text-4xl text-neutral-50 sm:text-5xl">Contatti</h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-neutral-200">
        Per informazioni, sopralluoghi o preventivi gratuiti: contattateci e troveremo insieme la
        soluzione giusta.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2">
      <!-- Contact details -->
      <div>
        <h2 class="font-heading text-2xl text-primary sm:text-3xl">Come raggiungerci</h2>

        <div class="mt-8 space-y-6">
          <!-- Address -->
          <div class="flex items-start gap-4">
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-800">Indirizzo</h3>
              <p class="mt-1 text-neutral-800">
                {address}, {city}
              </p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-800">Telefono</h3>
              <a
                href={`tel:${phone.replace(/\s/g, '')}`}
                class="mt-1 inline-block text-primary hover:underline"
              >
                {phone}
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-800">Email</h3>
              <a href={`mailto:${email}`} class="mt-1 inline-block text-primary hover:underline">
                {email}
              </a>
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="flex items-start gap-4">
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#25D366]/10"
            >
              <svg
                class="h-5 w-5 text-[#25D366]"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-800">WhatsApp</h3>
              <a
                href="https://wa.me/393355955786"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1 inline-block text-primary hover:underline"
              >
                +39 335 595 5786
              </a>
            </div>
          </div>

          <!-- Opening hours -->
          <div class="flex items-start gap-4">
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-800">Orari di apertura</h3>
              <table class="mt-2 text-sm text-neutral-800" aria-label="Orari di apertura">
                <thead class="sr-only">
                  <tr>
                    <th scope="col">Giorni</th>
                    <th scope="col">Orario</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    openingHours.map((oh) => (
                      <tr>
                        <th scope="row" class="pr-4 py-0.5 font-medium text-left">
                          {oh.days}
                        </th>
                        <td class="py-0.5">{oh.hours}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
              <p class="mt-2 text-xs text-neutral-500">
                Il laboratorio segue l'orario indicato. Gli uffici sono normalmente disponibili fino
                alle 19:00.
              </p>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-10">
          <a
            href="/preventivo"
            class="inline-block rounded-full bg-secondary px-8 py-3.5 text-base font-semibold text-neutral-50 shadow-lg transition-colors hover:bg-secondary-dark focus:outline-none focus:ring-2 focus:ring-secondary-light focus:ring-offset-2"
          >
            Richiedi un preventivo gratuito
          </a>
        </div>
      </div>

      <!-- Map + Weather -->
      <div class="space-y-6">
        <h2 class="font-heading text-2xl text-primary sm:text-3xl mb-6">Dove siamo</h2>
        <ContactMap />
        <WeatherWidget />
      </div>
    </div>
  </section>

  <!-- Zone servite -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <h2 class="font-heading text-3xl text-primary text-center sm:text-4xl mb-4" data-reveal>
        Zone servite
      </h2>
      <p
        class="mx-auto mt-4 max-w-2xl text-center text-lg leading-relaxed text-neutral-800"
        data-reveal
        data-delay="1"
      >
        Da Casale Monferrato operiamo in tutto il Nord-Ovest e oltre confine, con sopralluoghi
        gratuiti nelle aree principali.
      </p>

      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Piemonte -->
        <div data-reveal data-delay="1" class="group pb-1">
          <div
            class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-8 w-8 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                ></path>
              </svg>
            </div>
            <h3 class="mt-4 font-heading text-xl text-primary">Piemonte</h3>
            <p class="mt-2 text-neutral-800">
              La nostra zona principale. Casale Monferrato, Alessandria, Asti, Torino, Vercelli,
              Novara e tutte le province.
            </p>
            <span
              class="mt-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
              >Sopralluogo gratuito</span
            >
          </div>
        </div>

        <!-- Lombardia -->
        <div data-reveal data-delay="2" class="group pb-1">
          <div
            class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-8 w-8 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                ></path>
              </svg>
            </div>
            <h3 class="mt-4 font-heading text-xl text-primary">Lombardia</h3>
            <p class="mt-2 text-neutral-800">
              Gamma completa di servizi. Pavia, Milano, Vigevano, Voghera e province limitrofe.
            </p>
            <span
              class="mt-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
              >Sopralluogo gratuito</span
            >
          </div>
        </div>

        <!-- Liguria & Valle d'Aosta -->
        <div data-reveal data-delay="3" class="group pb-1">
          <div
            class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-8 w-8 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"
                ></path>
              </svg>
            </div>
            <h3 class="mt-4 font-heading text-xl text-primary">Liguria e Valle d'Aosta</h3>
            <p class="mt-2 text-neutral-800">
              Disponibili per installazioni di grandi dimensioni e progetti speciali su preventivo.
            </p>
            <span
              class="mt-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
              >Progetti speciali</span
            >
          </div>
        </div>

        <!-- Estero -->
        <div data-reveal data-delay="4" class="group pb-1">
          <div
            class="glass-hover glass-reflect h-full rounded-2xl border border-neutral-200 bg-surface p-8 text-center shadow-sm transition-all duration-200 group-hover:-translate-y-1"
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
            >
              <svg
                class="h-8 w-8 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"
                ></path>
              </svg>
            </div>
            <h3 class="mt-4 font-heading text-xl text-primary">Estero</h3>
            <p class="mt-2 text-neutral-800">
              Esperienza anche oltre confine. Contattateci per valutare insieme il vostro progetto.
            </p>
            <span
              class="mt-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
              >Valutazione su richiesta</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
