---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactMap from '../components/ContactMap.astro';
import WeatherWidget from '../components/WeatherWidget.astro';
import { fetchWithFallback, queries } from '../lib/sanity';
export const prerender = true;

// Fetch site settings from Sanity for contact details
interface OpeningHour { days: string; hours: string; }
interface SiteSettings {
  address?: string;
  city?: string;
  phone?: string;
  email?: string;
  openingHours?: OpeningHour[];
}

const settings = await fetchWithFallback<SiteSettings | null>(queries.siteSettings, null);

// Opening hours: Google Places data (build-time) → Sanity → static fallback
let googleHours: OpeningHour[] = [];
try {
  const hoursData = await import('../data/opening-hours.json');
  googleHours = hoursData.schedule || [];
} catch { /* file not yet generated */ }

const address = settings?.address || 'Strada Statale 31, 98/C';
const city = settings?.city || '15033 Casale Monferrato (AL)';
const phone = settings?.phone || '+39 0142 563728';
const email = settings?.email || 'info@vetreriamonferrina.com';
const openingHours: OpeningHour[] =
  settings?.openingHours && settings.openingHours.length > 0
    ? settings.openingHours
    : googleHours.length > 0
      ? googleHours
      : [
          { days: 'Lunedì - Venerdì', hours: '08:00 - 12:00 / 13:30 - 17:30' },
          { days: 'Sabato', hours: '08:00 - 12:00' },
          { days: 'Domenica', hours: 'Chiuso' },
        ];
---

<BaseLayout
  title="Contatti"
  description="Contatta la Vetreria Monferrina a Casale Monferrato: indirizzo, telefono, email e orari di apertura."
>
  <!-- Hero section -->
  <section class="bg-primary py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <h1 class="font-heading text-4xl text-neutral-50 sm:text-5xl">Contatti</h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-neutral-200">
        Per informazioni, sopralluoghi o preventivi gratuiti:
        contattateci e troveremo insieme la soluzione giusta.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2">
      <!-- Contact details -->
      <div>
        <h2 class="font-heading text-2xl text-primary">Come raggiungerci</h2>

        <div class="mt-8 space-y-6">
          <!-- Address -->
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10">
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-800">Indirizzo</h3>
              <p class="mt-1 text-neutral-700">
                {address}, {city}
              </p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10">
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-800">Telefono</h3>
              <a
                href={`tel:${phone.replace(/\s/g, '')}`}
                class="mt-1 inline-block text-primary hover:underline"
              >
                {phone}
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10">
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-800">Email</h3>
              <a
                href={`mailto:${email}`}
                class="mt-1 inline-block text-primary hover:underline"
              >
                {email}
              </a>
            </div>
          </div>

          <!-- Opening hours -->
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10">
              <svg
                class="h-5 w-5 text-primary"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-800">Orari di apertura</h3>
              <table class="mt-2 text-sm text-neutral-700">
                <tbody>
                  {openingHours.map((oh) => (
                    <tr>
                      <td class="pr-4 py-0.5 font-medium">{oh.days}</td>
                      <td class="py-0.5">{oh.hours}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
              <p class="mt-2 text-xs text-neutral-500">
                Il laboratorio segue l'orario indicato. Gli uffici sono normalmente disponibili fino alle 19:00.
              </p>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-10">
          <a
            href="/preventivo"
            class="inline-block rounded-full bg-secondary px-8 py-3.5 text-base font-semibold text-neutral-50 shadow-lg transition-colors hover:bg-secondary-dark focus:outline-none focus:ring-2 focus:ring-secondary-light focus:ring-offset-2"
          >
            Richiedi un preventivo gratuito
          </a>
        </div>
      </div>

      <!-- Map + Weather -->
      <div class="space-y-6">
        <h2 class="font-heading text-2xl text-primary mb-6">Dove siamo</h2>
        <ContactMap />
        <WeatherWidget />
      </div>
    </div>
  </section>
</BaseLayout>
