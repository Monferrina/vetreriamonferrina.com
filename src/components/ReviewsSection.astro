---
// src/components/ReviewsSection.astro
// Displays Google Reviews fetched at build time.
// Only reviews with rating >= 4 are shown (filtered in reviews.json).
// Data is validated at build time — any corrupted JSON fails the build.
import rawData from '../data/reviews.json';

// --- Build-time validation ---
interface ReviewEntry {
  author: string;
  rating: number;
  date: string;
  text: string;
}

interface ReviewsData {
  rating: number;
  totalReviews: number;
  placeId: string;
  lastUpdated: string;
  reviews: ReviewEntry[];
}

function validateReviews(data: unknown): ReviewsData {
  if (!data || typeof data !== 'object') {
    throw new Error('[ReviewsSection] reviews.json is not a valid object');
  }

  const d = data as Record<string, unknown>;

  if (typeof d.rating !== 'number' || d.rating < 0 || d.rating > 5) {
    throw new Error('[ReviewsSection] Invalid rating — must be 0-5');
  }
  if (typeof d.totalReviews !== 'number' || d.totalReviews < 0) {
    throw new Error('[ReviewsSection] Invalid totalReviews');
  }
  if (typeof d.lastUpdated !== 'string' || !/^\d{4}-\d{2}-\d{2}$/.test(d.lastUpdated)) {
    throw new Error('[ReviewsSection] Invalid lastUpdated — must be YYYY-MM-DD');
  }
  if (!Array.isArray(d.reviews)) {
    throw new Error('[ReviewsSection] reviews must be an array');
  }

  const MAX_REVIEWS = 50;
  const MAX_TEXT_LEN = 500;

  const reviews: ReviewEntry[] = (d.reviews as unknown[]).slice(0, MAX_REVIEWS).map((r, i) => {
    if (!r || typeof r !== 'object') {
      throw new Error(`[ReviewsSection] Review ${i} is not a valid object`);
    }
    const review = r as Record<string, unknown>;

    if (
      typeof review.author !== 'string' ||
      review.author.length === 0 ||
      review.author.length > 100
    ) {
      throw new Error(`[ReviewsSection] Review ${i}: invalid author`);
    }
    if (typeof review.rating !== 'number' || review.rating < 1 || review.rating > 5) {
      throw new Error(`[ReviewsSection] Review ${i}: invalid rating`);
    }
    if (typeof review.date !== 'string' || !/^\d{4}-\d{2}-\d{2}$/.test(review.date)) {
      throw new Error(`[ReviewsSection] Review ${i}: invalid date`);
    }
    if (typeof review.text !== 'string' || review.text.length === 0) {
      throw new Error(`[ReviewsSection] Review ${i}: empty text`);
    }

    return {
      author: review.author.slice(0, 100),
      rating: review.rating,
      date: review.date,
      // Truncate long texts for safety
      text: review.text.slice(0, MAX_TEXT_LEN),
    };
  });

  return {
    rating: d.rating as number,
    totalReviews: d.totalReviews as number,
    placeId: typeof d.placeId === 'string' ? d.placeId : '',
    lastUpdated: d.lastUpdated as string,
    reviews,
  };
}

const reviewsData = validateReviews(rawData);
const { rating, totalReviews, reviews } = reviewsData;
const fullStars = Math.floor(rating);
const hasHalfStar = rating - fullStars >= 0.3;
---

<section data-section="reviews" class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <!-- Shared SVG defs (defined once, avoids document-global ID collisions) -->
    {
      hasHalfStar && (
        <svg class="absolute h-0 w-0" aria-hidden="true">
          <defs>
            <linearGradient id="reviews-half-star">
              <stop offset="50%" stop-color="#FBBF24" />
              <stop offset="50%" stop-color="var(--color-neutral-200)" />
            </linearGradient>
          </defs>
        </svg>
      )
    }

    <!-- Header with overall rating -->
    <div class="text-center">
      <h2 class="font-heading text-3xl text-primary sm:text-4xl">Cosa dicono i nostri clienti</h2>
      <div class="mt-4 flex items-center justify-center gap-2">
        <!-- Stars -->
        <div class="flex items-center gap-0.5" role="img" aria-label={`Valutazione ${rating} su 5`}>
          {
            Array.from({ length: 5 }).map((_, i) => (
              <svg
                class={`h-6 w-6 ${i < fullStars ? 'text-amber-400' : i === fullStars && hasHalfStar ? 'text-amber-400' : 'text-neutral-200'}`}
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                {i < fullStars ? (
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                ) : i === fullStars && hasHalfStar ? (
                  <path
                    fill="url(#reviews-half-star)"
                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                  />
                ) : (
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                )}
              </svg>
            ))
          }
        </div>
        <span class="font-heading text-2xl text-primary">{rating}</span>
        <span class="text-neutral-700">su Google ({totalReviews} recensioni)</span>
      </div>
    </div>

    <!-- Review cards — auto-scrolling infinite carousel (CSS-only) -->
    <div
      class="reviews-carousel mt-12 overflow-hidden"
      role="region"
      aria-label="Recensioni clienti"
    >
      <div class="reviews-track flex gap-6">
        {/* Original + duplicate for seamless loop */}
        {
          [...reviews, ...reviews].map((review) => (
            <article class="flex w-80 shrink-0 flex-col rounded-2xl border border-neutral-200 bg-surface p-6 shadow-sm sm:w-96">
              <div class="flex items-center gap-0.5">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg
                    class={`h-4 w-4 ${i < review.rating ? 'text-amber-400' : 'text-neutral-200'}`}
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-neutral-700">"{review.text}"</p>
              <div class="mt-4 flex items-center gap-2 text-sm text-neutral-700">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-xs font-semibold text-primary">
                  {review.author.charAt(0)}
                </div>
                <div>
                  <p class="font-medium text-neutral-800">{review.author}</p>
                  <p class="text-xs text-neutral-700">
                    {new Date(review.date).toLocaleDateString('it-IT', {
                      month: 'long',
                      year: 'numeric',
                    })}
                  </p>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- Google attribution -->
    <p class="mt-8 text-center text-sm text-neutral-700">
      Recensioni da Google. Ultimo aggiornamento: {
        new Date(reviewsData.lastUpdated).toLocaleDateString('it-IT', {
          month: 'long',
          year: 'numeric',
        })
      }.
    </p>
  </div>
</section>

<style>
  /* Infinite auto-scroll — CSS only, zero JS */
  .reviews-track {
    animation: reviews-scroll 30s linear infinite;
  }

  /* Pause on hover so users can read */
  .reviews-carousel:hover .reviews-track {
    animation-play-state: paused;
  }

  @keyframes reviews-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .reviews-track {
      animation: none;
    }
    .reviews-carousel {
      overflow-x: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--color-neutral-200) transparent;
    }
  }
</style>
