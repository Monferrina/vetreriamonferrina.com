---
// src/components/Footer.astro
import { fetchWithFallback, queries } from '../lib/sanity';

const currentYear = new Date().getFullYear();

// Fetch site settings from Sanity for footer legal info
interface SiteSettings {
  companyName?: string;
  vatNumber?: string;
  address?: string;
  city?: string;
  phone?: string;
  email?: string;
}
const settings = await fetchWithFallback<SiteSettings | null>(queries.siteSettings, null);

// Use Sanity data if available, otherwise keep static defaults
const companyName = settings?.companyName || 'Vetreria Monferrina di Fioravanti Giuseppe';
const vatNumber = settings?.vatNumber || '01574530067';
const address = settings?.address || 'Strada Statale 31, 98/C';
const city = settings?.city || '15033 Casale Monferrato (AL)';
const phone = settings?.phone || '+39 0142 563728';
const email = settings?.email || 'vetreriamonferrina@gmail.com';
---

<footer
  class="border-t border-neutral-200 bg-neutral-100 text-neutral-800"
  style="view-transition-name: site-footer;"
>
  <div class="mx-auto max-w-7xl px-4 py-12 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Colonna 1: Ragione sociale -->
      <div>
        <h2 class="font-heading text-lg text-primary">Vetreria Monferrina</h2>
        <p class="mt-2 text-sm leading-relaxed">
          {companyName}
        </p>
        <p class="mt-1 text-sm">
          Sede legale: {address}, {city}
        </p>
        <p class="mt-1 text-sm">P.IVA: {vatNumber}</p>
      </div>

      <!-- Colonna 2: Contatti -->
      <div>
        <h3 class="font-heading text-lg text-primary">Contatti</h3>
        <ul class="mt-2 space-y-2 text-sm">
          <li>
            <a
              href={`tel:${phone.replace(/\s/g, '')}`}
              class="transition-colors hover:text-primary"
            >
              Tel: {phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${email}`} class="transition-colors hover:text-primary">
              {email}
            </a>
          </li>
        </ul>
        <!-- Social -->
        <div class="mt-4 flex items-center gap-3">
          <a
            href="https://www.facebook.com/p/Vetreria-Monferrina-100054607712479/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="text-neutral-500 transition-colors hover:text-primary"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/vetreriamonferrina/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="text-neutral-500 transition-colors hover:text-primary"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Colonna 3: Navigazione -->
      <div>
        <h3 class="font-heading text-lg text-primary">Navigazione</h3>
        <ul class="mt-2 space-y-2 text-sm">
          <li><a href="/" class="transition-colors hover:text-primary">Home</a></li>
          <li><a href="/chi-siamo" class="transition-colors hover:text-primary">Chi siamo</a></li>
          <li><a href="/servizi" class="transition-colors hover:text-primary">Servizi</a></li>
          <li><a href="/galleria" class="transition-colors hover:text-primary">Galleria</a></li>
          <li><a href="/contatti" class="transition-colors hover:text-primary">Contatti</a></li>
          <li><a href="/preventivo" class="transition-colors hover:text-primary">Preventivo</a></li>
        </ul>
      </div>

      <!-- Colonna 4: Legale -->
      <div>
        <h3 class="font-heading text-lg text-primary">Legale</h3>
        <ul class="mt-2 space-y-2 text-sm">
          <li>
            <a href="/privacy" class="transition-colors hover:text-primary"> Privacy Policy </a>
          </li>
          <li>
            <a href="/cookie" class="transition-colors hover:text-primary"> Cookie Policy </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 border-t border-neutral-200 pt-6 text-center text-sm text-neutral-800">
      <p>&copy; {currentYear} Vetreria Monferrina. Tutti i diritti riservati.</p>
    </div>
  </div>
</footer>
