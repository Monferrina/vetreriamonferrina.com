---
// src/components/Footer.astro
import { fetchWithFallback, queries } from '../lib/sanity';

const currentYear = new Date().getFullYear();

// Fetch site settings from Sanity for footer legal info
interface SiteSettings {
  companyName?: string;
  vatNumber?: string;
  address?: string;
  city?: string;
  phone?: string;
  email?: string;
}
const settings = await fetchWithFallback<SiteSettings | null>(queries.siteSettings, null);

// Use Sanity data if available, otherwise keep static defaults
const companyName = settings?.companyName || 'Vetreria Monferrina di Fioravanti Giuseppe';
const vatNumber = settings?.vatNumber || '01574530067';
const address = settings?.address || 'Strada Statale 31, 98/C';
const city = settings?.city || '15033 Casale Monferrato (AL)';
const phone = settings?.phone || '+39 0142 563728';
const email = settings?.email || 'info@vetreriamonferrina.com';
---

<footer class="border-t border-neutral-200 bg-neutral-100 text-neutral-700">
  <div class="mx-auto max-w-7xl px-4 py-12 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Colonna 1: Ragione sociale -->
      <div>
        <h2 class="font-heading text-lg text-primary">Vetreria Monferrina</h2>
        <p class="mt-2 text-sm leading-relaxed">
          {companyName}
        </p>
        <p class="mt-1 text-sm">
          Sede legale: {address}, {city}
        </p>
        <p class="mt-1 text-sm">P.IVA: {vatNumber}</p>
      </div>

      <!-- Colonna 2: Contatti -->
      <div>
        <h3 class="font-heading text-lg text-primary">Contatti</h3>
        <ul class="mt-2 space-y-2 text-sm">
          <li>
            <a
              href={`tel:${phone.replace(/\s/g, '')}`}
              class="transition-colors hover:text-primary"
            >
              Tel: {phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${email}`}
              class="transition-colors hover:text-primary"
            >
              {email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Colonna 3: Navigazione (due colonne) -->
      <div>
        <h3 class="font-heading text-lg text-primary">Navigazione</h3>
        <div class="mt-2 grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
          <a href="/" class="transition-colors hover:text-primary">Home</a>
          <a href="/galleria" class="transition-colors hover:text-primary">Galleria</a>
          <a href="/chi-siamo" class="transition-colors hover:text-primary">Chi siamo</a>
          <a href="/contatti" class="transition-colors hover:text-primary">Contatti</a>
          <a href="/servizi" class="transition-colors hover:text-primary">Servizi</a>
          <a href="/preventivo" class="transition-colors hover:text-primary">Preventivo</a>
        </div>
      </div>

      <!-- Colonna 4: Legale -->
      <div>
        <h3 class="font-heading text-lg text-primary">Legale</h3>
        <ul class="mt-2 space-y-2 text-sm">
          <li>
            <a href="/privacy" class="transition-colors hover:text-primary">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/cookie" class="transition-colors hover:text-primary">
              Cookie Policy
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-10 border-t border-neutral-200 pt-6 text-center text-sm text-neutral-700"
    >
      <p>&copy; {currentYear} Vetreria Monferrina. Tutti i diritti riservati.</p>
    </div>
  </div>
</footer>
