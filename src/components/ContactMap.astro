---
// src/components/ContactMap.astro
// Google Maps Embed — zero JavaScript, zero dipendenze esterne.
const PLACE_ID = 'ChIJcx_Q1ESwh0cRqv3FdLTrU1w';
const API_KEY = import.meta.env.GOOGLE_PLACES_API_KEY ?? '';
const embedUrl = `https://www.google.com/maps/embed/v1/place?key=${API_KEY}&q=place_id:${PLACE_ID}&zoom=17&language=it`;
---

<div class="relative z-0 overflow-hidden rounded-xl border border-neutral-200">
  <iframe
    src={embedUrl}
    width="100%"
    height="400"
    style="border:0;"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen
    title="Mappa posizione Vetreria Monferrina — Strada Statale 31, 98/C, Casale Monferrato"
  ></iframe>
  <p class="bg-neutral-100 px-4 py-2 text-sm text-neutral-700">
    <a
      href={`https://www.google.com/maps/place/?q=place_id:${PLACE_ID}`}
      target="_blank"
      rel="noopener noreferrer"
      class="text-primary underline underline-offset-2"
    >
      Apri in Google Maps
    </a>
  </p>
</div>
