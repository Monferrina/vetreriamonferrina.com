---
// src/components/StatsSection.astro

const stats = [
  { value: '40+', label: 'Anni di esperienza' },
  { value: 'Casale Monferrato', label: 'Dal cuore del Monferrato' },
  { value: 'Su misura', label: 'Ogni lavoro è unico' },
];
---

<section data-section="stats" class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-3">
      {
        stats.map((stat, i) => (
          <div class="text-center" data-reveal data-delay={String(i + 1)}>
            <p class="font-heading text-3xl text-primary sm:text-4xl">{stat.value}</p>
            <p class="mt-2 text-lg text-neutral-700">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
