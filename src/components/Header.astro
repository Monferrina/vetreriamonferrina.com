---
// src/components/Header.astro
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/chi-siamo', label: 'Chi siamo' },
  { href: '/servizi', label: 'Servizi' },
  { href: '/galleria', label: 'Galleria' },
  { href: '/contatti', label: 'Contatti' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header
  class="sticky top-0 z-50 border-b border-neutral-200 bg-neutral-50/80 backdrop-blur-md"
  style="view-transition-name: site-header;"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 lg:px-8">
    <a href="/" class="flex items-center gap-2" aria-label="Vetreria Monferrina">
      <img
        src="/images/logo-monogram.svg"
        alt=""
        width="42"
        height="48"
        class="h-9 w-auto lg:h-11"
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
      <span class="font-heading text-lg text-primary lg:text-xl"> Vetreria Monferrina </span>
    </a>

    <nav aria-label="Navigazione principale" class="hidden md:block">
      <ul class="flex items-center gap-1 lg:gap-2">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'rounded-md px-3 py-2 text-sm font-medium transition-colors',
                  isActive(href)
                    ? 'bg-primary/10 text-primary'
                    : 'text-neutral-700 hover:bg-neutral-100 hover:text-primary',
                ]}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="/preventivo"
            class="ml-2 inline-block rounded-full bg-primary px-5 py-2 text-sm font-semibold text-neutral-50 transition-colors hover:bg-primary-dark"
          >
            Preventivo
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
