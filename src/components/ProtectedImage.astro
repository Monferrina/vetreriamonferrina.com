---
// src/components/ProtectedImage.astro
// Wrapper that prevents casual image saving/downloading.
// Layers: transparent shield div + CSS disable drag/select + JS context-menu block.

interface Props {
  src: string;
  alt: string;
  class?: string;
  wrapperClass?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  sizes?: string;
}

const {
  src,
  alt,
  class: imgClass = '',
  wrapperClass = '',
  loading = 'lazy',
  fetchpriority,
  width,
  height,
  sizes,
} = Astro.props;
---

<div class:list={['protected-img-wrap', wrapperClass]}>
  <img
    src={src}
    alt={alt}
    class:list={['protected-img', imgClass]}
    loading={loading}
    decoding="async"
    width={width}
    height={height}
    fetchpriority={fetchpriority}
    sizes={sizes}
  />
  <!-- Transparent shield blocks right-click / long-press on the actual image -->
  <div class="protected-img-shield" aria-hidden="true"></div>
</div>

<style>
  .protected-img-wrap {
    position: relative;
    overflow: hidden;
    user-select: none;
    -webkit-user-select: none;
    -webkit-touch-callout: none;
  }

  .protected-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    -webkit-user-drag: none;
    user-drag: none;
    pointer-events: none;
  }

  .protected-img-shield {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: transparent;
    cursor: default;
  }
</style>
