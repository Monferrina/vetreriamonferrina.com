---
// src/components/GalleryGrid.astro
// Professional masonry gallery with blur-up loading and category filtering.
// Accepts optional Sanity items via props; falls back to static data.

import { urlFor } from '../lib/sanity';
import ProtectedImage from './ProtectedImage.astro';

interface GalleryItem {
  id: number;
  title: string;
  category: string;
  categoryLabel: string;
  imageUrl?: string;
  size?: 'featured' | 'tall';
}

interface SanityGalleryItem {
  title: string;
  category: string;
  image?: unknown;
}

interface Props {
  items?: SanityGalleryItem[] | null;
}

const { items: sanityItems } = Astro.props;

