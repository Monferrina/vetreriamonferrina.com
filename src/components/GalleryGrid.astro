// Use Sanity items if provided, otherwise fall back to static data
const items: GalleryItem[] = sanityItems
  ? sanityItems.map((item, index) => ({
      id: index + 1,
      title: item.title,
      category: item.category,
      categoryLabel: categoryLabels[item.category] || item.category,
      imageUrl: item.image ? urlFor(item.image).url() : undefined,
    }))
  : staticItems;
---

<div class="gallery-masonry" data-gallery-grid>
  {
    items.map((item, index) => {
      const aspectClass =
        item.size === 'featured'
          ? 'aspect-[16/9]'
          : item.size === 'tall'
            ? 'aspect-[3/4]'
            : 'aspect-[4/3]';
      const sizeClass = item.size === 'featured' ? 'gallery-featured' : '';
      const isAboveFold = index < 6;

      return (
        <button
          type="button"
          class:list={[
            'gallery-blur-up group relative overflow-hidden rounded-xl text-left transition-shadow hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2',
            sizeClass,
          ]}
          data-category={item.category}
          data-gallery-item
          data-gallery-id={item.id}
          data-gallery-title={item.title}
        >
          {item.imageUrl ? (
            <div class={`${aspectClass} overflow-hidden`}>
              <ProtectedImage
                src={item.imageUrl}
                alt={item.title}
                class="transition-transform duration-300 group-hover:scale-105"
                wrapperClass="h-full w-full bg-neutral-200"
                width={item.size === 'featured' ? 1200 : 800}
                height={item.size === 'featured' ? 900 : item.size === 'tall' ? 800 : 600}
                sizes={
                  item.size === 'featured'
                    ? '(min-width: 1024px) 66vw, 100vw'
                    : '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw'
                }
                loading={isAboveFold ? 'eager' : 'lazy'}
                fetchpriority={index === 0 ? 'high' : undefined}
              />
            </div>
          ) : (
            <div
              class={`flex ${aspectClass} items-center justify-center bg-neutral-200 transition-transform group-hover:scale-105`}
            >
              <div class="text-center text-neutral-400">
                <svg
                  class="mx-auto h-10 w-10"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"
                  />
                </svg>
                <p class="mt-1 text-xs">Foto in arrivo</p>
              </div>
            </div>
          )}

          {/* Info overlay */}
          <div class="absolute inset-x-0 bottom-0 z-[2] bg-gradient-to-t from-black/80 to-transparent p-3 pt-8">
            <span class="mb-1 inline-block rounded-full bg-surface/90 px-2 py-0.5 text-xs font-semibold text-neutral-800">
              {item.categoryLabel}
            </span>
            <p class="text-sm font-medium text-white">{item.title}</p>
          </div>
        </button>
      );
    })
  }
</div>
