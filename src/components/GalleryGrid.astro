---
// src/components/GalleryGrid.astro
// Responsive gallery grid with placeholder items and category filtering.
// Accepts optional Sanity items via props; falls back to static data.

import { urlFor } from '../lib/sanity';

interface GalleryItem {
  id: number;
  title: string;
  category: string;
  categoryLabel: string;
  imageUrl?: string;
}

interface SanityGalleryItem {
  title: string;
  category: string;
  image?: unknown;
}

interface Props {
  items?: SanityGalleryItem[] | null;
}

const { items: sanityItems } = Astro.props;

const categoryLabels: Record<string, string> = {
  installazioni: 'Installazioni',
  vetri: 'Vetri',
  lavorazioni: 'Lavorazioni',
};

const staticItems: GalleryItem[] = [
  { id: 1, title: 'Box doccia su misura', category: 'installazioni', categoryLabel: 'Installazioni' },
  { id: 2, title: 'Parapetto in vetro temperato', category: 'installazioni', categoryLabel: 'Installazioni' },
  { id: 3, title: 'Pensilina ingresso', category: 'installazioni', categoryLabel: 'Installazioni' },
  { id: 4, title: 'Vetro stratificato satinato', category: 'vetri', categoryLabel: 'Vetri' },
  { id: 5, title: 'Vetrocamera doppio', category: 'vetri', categoryLabel: 'Vetri' },
  { id: 6, title: 'Specchio su misura', category: 'vetri', categoryLabel: 'Vetri' },
  { id: 7, title: 'Sagomatura su disegno', category: 'lavorazioni', categoryLabel: 'Lavorazioni' },
  { id: 8, title: 'Molatura a filo lucido', category: 'lavorazioni', categoryLabel: 'Lavorazioni' },
];

// Use Sanity items if provided, otherwise fall back to static data
const items: GalleryItem[] = sanityItems
  ? sanityItems.map((item, index) => ({
      id: index + 1,
      title: item.title,
      category: item.category,
      categoryLabel: categoryLabels[item.category] || item.category,
      imageUrl: item.image ? urlFor(item.image).url() : undefined,
    }))
  : staticItems;
---

<div
  class="grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 lg:grid-cols-4"
  data-gallery-grid
>
  {items.map((item) => (
    <button
      type="button"
      class="group relative overflow-hidden rounded-xl text-left transition-shadow hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
      data-category={item.category}
      data-gallery-item
      data-gallery-id={item.id}
      data-gallery-title={item.title}
      aria-label={`Apri ${item.title}`}
    >
      {/* Image: Sanity image or placeholder */}
      {item.imageUrl ? (
        <div class="aspect-[4/3] overflow-hidden bg-neutral-200 transition-transform group-hover:scale-105">
          <img
            src={item.imageUrl}
            alt={item.title}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="flex aspect-[4/3] items-center justify-center bg-neutral-200 transition-transform group-hover:scale-105">
          <div class="text-center text-neutral-400">
            <svg
              class="mx-auto h-10 w-10"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"
              />
            </svg>
            <p class="mt-1 text-xs">Foto in arrivo</p>
          </div>
        </div>
      )}

      {/* Info overlay */}
      <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-3 pt-8">
        <span class="mb-1 inline-block rounded-full bg-secondary px-2 py-0.5 text-xs font-semibold text-neutral-50">
          {item.categoryLabel}
        </span>
        <p class="text-sm font-medium text-neutral-50">{item.title}</p>
      </div>
    </button>
  ))}
</div>
