---
// src/components/GalleryGrid.astro
// Professional masonry gallery with blur-up loading and category filtering.
// Accepts optional Sanity items via props; falls back to static data.

import { urlFor } from '../lib/sanity';
import ProtectedImage from './ProtectedImage.astro';

interface GalleryItem {
  id: number;
  title: string;
  category: string;
  categoryLabel: string;
  imageUrl?: string;
  size?: 'featured' | 'tall';
}

interface SanityGalleryItem {
  title: string;
  category: string;
  image?: unknown;
}

interface Props {
  items?: SanityGalleryItem[] | null;
}

const { items: sanityItems } = Astro.props;

const categoryLabels: Record<string, string> = {
  installazioni: 'Installazioni',
  vetri: 'Vetri',
  lavorazioni: 'Lavorazioni',
};

const staticItems: GalleryItem[] = [
  // --- Installazioni ---
  {
    id: 1,
    title: 'Posa vetrata ad arco in villa',
    category: 'installazioni',
    categoryLabel: 'Installazioni',
    imageUrl: '/images/gallery/installazioni-arco-villa.webp',
    size: 'featured',
  },
  {
    id: 2,
    title: 'Installazione vetro in arco mattoni',
    category: 'installazioni',
    categoryLabel: 'Installazioni',
    imageUrl: '/images/gallery/installazioni-arco-mattoni.webp',
  },
  {
    id: 3,
    title: 'Posa facciata vetrata commerciale',
    category: 'installazioni',
    categoryLabel: 'Installazioni',
    imageUrl: '/images/gallery/installazioni-facciata.webp',
    size: 'featured',
  },
  {
    id: 4,
    title: 'Posa vetri su casa in legno',
    category: 'installazioni',
    categoryLabel: 'Installazioni',
    imageUrl: '/images/gallery/installazioni-casa-legno.webp',
  },
  {
    id: 5,
    title: 'Installazione pensilina in vetro',
    category: 'installazioni',
    categoryLabel: 'Installazioni',
    imageUrl: '/images/gallery/installazioni-pensilina.webp',
    size: 'tall',
  },
  {
    id: 6,
    title: 'Posa grandi vetrate',
    category: 'installazioni',
    categoryLabel: 'Installazioni',
    imageUrl: '/images/gallery/installazioni-casa-legno-2.webp',
  },
  {
    id: 7,
    title: "Installazione dall'interno",
    category: 'installazioni',
    categoryLabel: 'Installazioni',
    imageUrl: '/images/gallery/installazioni-interno.webp',
  },
  {
    id: 8,
    title: 'Consegna e posa in cantiere',
    category: 'installazioni',
    categoryLabel: 'Installazioni',
    imageUrl: '/images/gallery/installazioni-consegna.webp',
  },
  // --- Vetri (parapetti, vetrate, porte) ---
  {
    id: 9,
    title: 'Parapetto balcone in vetro moderno',
    category: 'vetri',
    categoryLabel: 'Vetri',
    imageUrl: '/images/gallery/vetri-parapetto-moderno.webp',
  },
  {
    id: 10,
    title: 'Parapetto scala interna in vetro',
    category: 'vetri',
    categoryLabel: 'Vetri',
    imageUrl: '/images/gallery/vetri-scala-interna.webp',
    size: 'tall',
  },
  {
    id: 11,
    title: 'Parapetto terrazza',
    category: 'vetri',
    categoryLabel: 'Vetri',
    imageUrl: '/images/gallery/vetri-parapetto-terrazza.webp',
  },
  {
    id: 12,
    title: 'Parapetto balcone residenziale',
    category: 'vetri',
    categoryLabel: 'Vetri',
    imageUrl: '/images/gallery/vetri-balcone-residenziale.webp',
  },
  {
    id: 13,
    title: 'Grande vetrata con colonne in pietra',
    category: 'vetri',
    categoryLabel: 'Vetri',
    imageUrl: '/images/gallery/vetri-grande-vetrata.webp',
    size: 'featured',
  },
  {
    id: 14,
    title: 'Vetrata ad arco con profili bianchi',
    category: 'vetri',
    categoryLabel: 'Vetri',
    imageUrl: '/images/gallery/vetri-arco-bianco.webp',
  },
  {
    id: 15,
    title: 'Facciata vetrata commerciale',
    category: 'vetri',
    categoryLabel: 'Vetri',
    imageUrl: '/images/gallery/vetri-facciata-commerciale.webp',
  },
  {
    id: 16,
    title: 'Porta in vetro per ingresso',
    category: 'vetri',
    categoryLabel: 'Vetri',
    imageUrl: '/images/gallery/vetri-porta-ingresso.webp',
  },
  {
    id: 17,
    title: 'Chiusura in vetro su struttura in granito',
    category: 'vetri',
    categoryLabel: 'Vetri',
    imageUrl: '/images/gallery/vetri-chiusura-granito.webp',
  },
  // --- Lavorazioni su misura ---
  {
    id: 18,
    title: 'Porta scorrevole con fiori dipinti',
    category: 'lavorazioni',
    categoryLabel: 'Lavorazioni',
    imageUrl: '/images/gallery/lavorazioni-porta-fiori.webp',
    size: 'tall',
  },
  {
    id: 19,
    title: 'Finestra ad arco con vetro sabbiato',
    category: 'lavorazioni',
    categoryLabel: 'Lavorazioni',
    imageUrl: '/images/gallery/lavorazioni-arco-sabbiato.webp',
  },
  {
    id: 20,
    title: 'Porta in vetro decorato con airone',
    category: 'lavorazioni',
    categoryLabel: 'Lavorazioni',
    imageUrl: '/images/gallery/lavorazioni-porta-airone.webp',
  },
  {
    id: 21,
    title: 'Pannello con incisione rose',
    category: 'lavorazioni',
    categoryLabel: 'Lavorazioni',
    imageUrl: '/images/gallery/lavorazioni-pannello-rose.webp',
  },
  {
    id: 22,
    title: 'Vetro curvo per imbarcazione',
    category: 'lavorazioni',
    categoryLabel: 'Lavorazioni',
    imageUrl: '/images/gallery/lavorazioni-vetro-barca.webp',
  },
];

// Use Sanity items if provided, otherwise fall back to static data
const items: GalleryItem[] = sanityItems
  ? sanityItems.map((item, index) => ({
      id: index + 1,
      title: item.title,
      category: item.category,
      categoryLabel: categoryLabels[item.category] || item.category,
      imageUrl: item.image ? urlFor(item.image).url() : undefined,
    }))
  : staticItems;
---

<div class="gallery-masonry" data-gallery-grid>
  {
    items.map((item) => {
      const aspectClass =
        item.size === 'featured'
          ? 'aspect-[16/9]'
          : item.size === 'tall'
            ? 'aspect-[3/4]'
            : 'aspect-[4/3]';
      const sizeClass = item.size === 'featured' ? 'gallery-featured' : '';

      return (
        <button
          type="button"
          class:list={[
            'gallery-blur-up group relative overflow-hidden rounded-xl text-left transition-shadow hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2',
            sizeClass,
          ]}
          data-category={item.category}
          data-gallery-item
          data-gallery-id={item.id}
          data-gallery-title={item.title}
          aria-label={`Apri ${item.title}`}
        >
          {item.imageUrl ? (
            <div class={`${aspectClass} overflow-hidden`}>
              <ProtectedImage
                src={item.imageUrl}
                alt={item.title}
                class="transition-transform duration-300 group-hover:scale-105"
                wrapperClass="h-full w-full bg-neutral-200"
                width={item.size === 'featured' ? 1200 : 600}
                height={item.size === 'featured' ? 675 : item.size === 'tall' ? 800 : 450}
              />
            </div>
          ) : (
            <div
              class={`flex ${aspectClass} items-center justify-center bg-neutral-200 transition-transform group-hover:scale-105`}
            >
              <div class="text-center text-neutral-400">
                <svg
                  class="mx-auto h-10 w-10"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"
                  />
                </svg>
                <p class="mt-1 text-xs">Foto in arrivo</p>
              </div>
            </div>
          )}

          {/* Info overlay */}
          <div class="absolute inset-x-0 bottom-0 z-[2] bg-gradient-to-t from-black/70 to-transparent p-3 pt-8">
            <span class="mb-1 inline-block rounded-full bg-secondary px-2 py-0.5 text-xs font-semibold text-neutral-50">
              {item.categoryLabel}
            </span>
            <p class="text-sm font-medium text-neutral-50">{item.title}</p>
          </div>
        </button>
      );
    })
  }
</div>
