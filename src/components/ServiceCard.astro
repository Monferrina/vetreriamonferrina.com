---
// src/components/ServiceCard.astro
import ProtectedImage from './ProtectedImage.astro';

export interface Props {
  name: string;
  description: string;
  slug: string;
  category: string;
  image?: string;
}

const { name, description, slug, category, image } = Astro.props;
---

<div class="group pb-1" data-service-item data-service-category={category}>
  <article
    class="glass-hover glass-reflect flex flex-col overflow-hidden rounded-2xl border border-neutral-200 bg-surface shadow-sm transition-all duration-200 group-hover:-translate-y-1"
  >
    {
      image ? (
        <div class="aspect-[4/3] overflow-hidden">
          <ProtectedImage
            src={image}
            alt={name}
            class="transition-transform duration-300 group-hover:scale-105"
            wrapperClass="h-full w-full bg-neutral-200"
            width={800}
            height={600}
          />
        </div>
      ) : (
        <div class="aspect-[4/3] overflow-hidden bg-neutral-200">
          <div class="flex h-full items-center justify-center text-neutral-400 transition-transform duration-300 group-hover:scale-105">
            <div class="text-center">
              <svg
                class="mx-auto h-10 w-10"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"
                />
              </svg>
              <p class="mt-1 text-xs">Foto in arrivo</p>
            </div>
          </div>
        </div>
      )
    }

    <div class="flex flex-1 flex-col p-6">
      <h3 class="font-heading text-xl text-primary">{name}</h3>
      <p class="mt-2 flex-1 leading-relaxed text-neutral-800">{description}</p>
      <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2">
        <a
          href={`/servizi/${slug}`}
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-colors hover:text-primary-dark"
        >
          Scopri di più
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
        <a
          href={`/galleria?categoria=${category}`}
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary/70 transition-colors hover:text-primary"
        >
          Galleria
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </article>
</div>
