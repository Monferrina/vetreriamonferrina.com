---
// src/components/ServiceCard.astro

export interface Props {
  name: string;
  description: string;
  slug: string;
}

const { name, description, slug } = Astro.props;
---

<article
  class="group flex flex-col rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md"
>
  <h3 class="font-heading text-xl text-primary">{name}</h3>
  <p class="mt-2 flex-1 leading-relaxed text-neutral-700">{description}</p>
  <a
    href={`/preventivo?servizio=${slug}`}
    class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-secondary transition-colors hover:text-secondary-dark"
  >
    Richiedi preventivo
    <svg
      class="h-4 w-4 transition-transform group-hover:translate-x-1"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
      />
    </svg>
  </a>
</article>
