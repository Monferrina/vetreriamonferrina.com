---
// src/components/ServiceCard.astro

export interface Props {
  name: string;
  description: string;
  slug: string;
}

const { name, description, slug } = Astro.props;
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl border border-neutral-200 bg-surface shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md"
>
  <!-- Image area (placeholder — real photos via Sanity later) -->
  <div class="aspect-[4/3] overflow-hidden bg-neutral-200">
    <div
      class="flex h-full items-center justify-center text-neutral-400 transition-transform duration-300 group-hover:scale-105"
    >
      <div class="text-center">
        <svg
          class="mx-auto h-10 w-10"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"
          ></path>
        </svg>
        <p class="mt-1 text-xs">Foto in arrivo</p>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-heading text-xl text-primary">{name}</h3>
    <p class="mt-2 flex-1 leading-relaxed text-neutral-700">{description}</p>
    <a
      href={`/preventivo?servizio=${slug}`}
      class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-secondary transition-colors hover:text-secondary-dark"
    >
      Richiedi preventivo
      <svg
        class="h-4 w-4 transition-transform group-hover:translate-x-1"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
        ></path>
      </svg>
    </a>
  </div>
</article>
