---
// src/components/CtaSection.astro
import GlassPanel from './GlassPanel.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hai un progetto? Parliamone.',
  description = 'Contattaci per un preventivo gratuito e senza impegno. Offriamo sopralluoghi gratuiti in Piemonte e Lombardia.',
} = Astro.props;
---

<section data-section="cta" class="bg-primary py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 text-center lg:px-8">
    <GlassPanel class="mx-auto max-w-2xl">
      <h2 class="font-heading text-3xl text-neutral-50 sm:text-4xl" data-reveal>
        {title}
      </h2>

      <p
        class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-neutral-200"
        data-reveal
        data-delay="1"
      >
        {description}
      </p>

      <div
        class="mt-10 flex flex-wrap items-center justify-center gap-4"
        data-reveal
        data-delay="2"
      >
        <a
          href="/preventivo"
          class="inline-block rounded-full bg-secondary px-8 py-3.5 text-base font-semibold text-neutral-50 shadow-lg transition-colors hover:bg-secondary-dark focus:outline-none focus:ring-2 focus:ring-secondary-light focus:ring-offset-2 focus:ring-offset-primary"
        >
          Richiedi preventivo
        </a>

        <a
          href="/contatti"
          class="inline-flex items-center gap-2 rounded-full px-6 py-3.5 text-base font-medium text-neutral-50 transition-colors hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-neutral-50 focus:ring-offset-2 focus:ring-offset-primary"
        >
          Oppure chiamaci
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
            ></path>
          </svg>
        </a>
      </div>
    </GlassPanel>
  </div>
</section>
