---
// src/components/MobileMenu.astro
export interface Props {
  navLinks: { href: string; label: string }[];
  pathname: string;
}

const { navLinks, pathname } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<div
  class="fixed inset-0 z-[60] hidden md:hidden"
  data-mobile-menu
  role="dialog"
  aria-modal="true"
  aria-label="Menu di navigazione"
>
  <!-- Overlay -->
  <div
    class="absolute inset-0 bg-neutral-900/50 opacity-0 transition-opacity duration-300 motion-reduce:transition-none"
    data-menu-overlay
  >
  </div>

  <!-- Slide-in panel -->
  <div
    class="absolute inset-y-0 right-0 z-10 w-full max-w-xs translate-x-full bg-neutral-50 shadow-xl transition-transform duration-300 motion-reduce:transition-none"
    data-menu-panel
  >
    <div class="flex items-center justify-between border-b border-neutral-200 px-4 py-3">
      <span class="font-heading text-lg text-primary">Menu</span>
      <button
        type="button"
        class="inline-flex items-center justify-center rounded-md p-2 text-neutral-700 hover:bg-neutral-100 hover:text-primary"
        aria-label="Chiudi menu"
        data-menu-close
      >
        <svg
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <nav aria-label="Navigazione mobile" class="px-4 py-6">
      <ul class="flex flex-col gap-1">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'block rounded-md px-3 py-3 text-base font-medium transition-colors',
                  isActive(href)
                    ? 'bg-primary/10 text-primary'
                    : 'text-neutral-700 hover:bg-neutral-100 hover:text-primary',
                ]}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))
        }
        <li class="mt-4">
          <a
            href="/preventivo"
            class="block rounded-full bg-primary px-5 py-3 text-center text-base font-semibold text-neutral-50 transition-colors hover:bg-primary-dark"
          >
            Preventivo
          </a>
        </li>
      </ul>
    </nav>
  </div>
</div>
