---
// src/components/BottomNav.astro
// Fixed bottom tab bar for mobile — replaces hamburger menu.
// Visible only on screens below md breakpoint.
// Respects safe areas on all devices (iPhone notch, Android gesture nav).

const pathname = Astro.url.pathname;

const tabs = [
  {
    href: '/',
    label: 'Home',
    icon: 'home',
  },
  {
    href: '/servizi',
    label: 'Servizi',
    icon: 'servizi',
  },
  {
    href: '/galleria',
    label: 'Galleria',
    icon: 'galleria',
  },
  {
    href: '/contatti',
    label: 'Contatti',
    icon: 'contatti',
  },
  {
    href: '/preventivo',
    label: 'Preventivo',
    icon: 'preventivo',
    cta: true,
  },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav
  class="fixed bottom-0 left-0 right-0 z-50 border-t border-neutral-200 bg-neutral-50/95 backdrop-blur-md md:hidden"
  style="padding-bottom: env(safe-area-inset-bottom, 0px); transform: translateZ(0); -webkit-transform: translateZ(0); view-transition-name: bottom-nav;"
  aria-label="Navigazione principale"
  data-bottom-nav
>
  <div class="flex h-14 items-center justify-around">
    {
      tabs.map((tab) => (
        <a
          href={tab.href}
          class:list={[
            'relative flex flex-col items-center justify-center gap-0.5 px-2 py-1.5 text-[10px] font-medium transition-colors min-w-0 w-full min-h-[44px]',
            tab.cta && isActive(tab.href)
              ? 'text-secondary-dark'
              : tab.cta
                ? 'text-secondary-dark'
                : isActive(tab.href)
                  ? 'text-primary'
                  : 'text-neutral-600',
          ]}
          aria-current={isActive(tab.href) ? 'page' : undefined}
        >
          <span class="relative">
            {tab.icon === 'home' && (
              <svg
                class="h-[22px] w-[22px]"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width={isActive(tab.href) ? '2' : '1.5'}
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
                />
              </svg>
            )}
            {tab.icon === 'servizi' && (
              <svg
                class="h-[22px] w-[22px]"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width={isActive(tab.href) ? '2' : '1.5'}
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"
                />
              </svg>
            )}
            {tab.icon === 'galleria' && (
              <svg
                class="h-[22px] w-[22px]"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width={isActive(tab.href) ? '2' : '1.5'}
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"
                />
              </svg>
            )}
            {tab.icon === 'contatti' && (
              <svg
                class="h-[22px] w-[22px]"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width={isActive(tab.href) ? '2' : '1.5'}
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                />
              </svg>
            )}
            {tab.icon === 'preventivo' && (
              <svg
                class="h-[22px] w-[22px]"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width={isActive(tab.href) ? '2' : '1.5'}
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
                />
              </svg>
            )}
          </span>
          <span class="truncate">{tab.label}</span>
          {isActive(tab.href) && (
            <span
              class:list={[
                'absolute -bottom-0.5 h-1 w-1 rounded-full',
                tab.cta ? 'bg-secondary-dark' : 'bg-primary',
              ]}
              aria-hidden="true"
            />
          )}
        </a>
      ))
    }
  </div>
</nav>
