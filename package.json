{
  "name": "monferrinaproject",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "astro check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@sanity/client": "^7.22.1",
    "@sanity/image-url": "^2.1.1",
    "@tailwindcss/vite": "^4.3.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.4.8",
    "resend": "^6.14.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@vitest/coverage-v8": "^4.1.9",
    "checkly": "latest",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.0.0",
    "happy-dom": "^20.10.4",
    "husky": "^9.1.7",
    "jiti": "^2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@vercel/functions": {
      "ws": "^8.21.0"
    },
    "@lhci/cli": {
      "tmp": "^0.2.6",
      "uuid": "^11.1.1"
    }
  }
}
