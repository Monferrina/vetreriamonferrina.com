    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "resend": "^6.9.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "happy-dom": "^20.7.0",
    "vitest": "^4.0.18"
  }
